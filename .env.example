# ── Onírica — template de variáveis de ambiente ──
# Copie para .env.local e preencha os valores.

# Claude API (Anthropic) — necessária para a prévia com IA
ANTHROPIC_API_KEY=

# Modelo da prévia (default: claude-opus-4-6). Para baratear o custo por lead:
# claude-sonnet-4-6 ou claude-haiku-4-5
ANTHROPIC_MODEL=claude-sonnet-4-6

# URL do checkout hospedado na Cakto
NEXT_PUBLIC_CAKTO_CHECKOUT_URL=

# Modelo dos entregáveis pagos (default: claude-opus-4-8). Override opcional.
# DELIVERABLES_MODEL=

# ── Supabase (persistência das análises) ──
SUPABASE_URL=
# Chave pública (publishable) — não é secreta
SUPABASE_PUBLISHABLE_KEY=
# Chave SECRETA (service role / secret) — copiar do dashboard Supabase
# Settings > API Keys. NUNCA commitar o valor real.
SUPABASE_SECRET_KEY=

# ── Resend (envio de e-mail de entrega) ──
RESEND_API_KEY=
RESEND_FROM="Onírica <onirica@metodoonirica.com>"

# URL base do site (para montar o link de acesso na entrega)
SITE_URL=https://metodoonirica.com

# ── Cakto (webhook) ──
# Segredo do webhook definido no painel da Cakto, validado no payload.
CAKTO_WEBHOOK_SECRET=
